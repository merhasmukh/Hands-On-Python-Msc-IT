# ========================================================
# .env.example
# ========================================================
# This is a template for the environment variables required 
# by this application. 
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Fill in the actual values for your local environment
# 3. DO NOT COMMIT the `.env` file to version control!
# ========================================================

# Application Settings
APP_ENV=development
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=my_app_db
DATABASE_USER=root
DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# Security / Authentication
# Generate a secret key using: openssl rand -hex 32
SECRET_KEY=YOUR_SUPER_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
